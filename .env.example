# Stripe Projects writes provisioned service credentials to .env.
# This example documents the values used by the template.

APP_NAME="Gym Cancellation SaaS"
CHECKOUT_DISPLAY_NAME="Gym Cancellation SaaS"
CHECKOUT_AMOUNT_CENTS=1299
CHECKOUT_CURRENCY=usd
STRIPE_API_VERSION=2025-09-30.clover

STRIPE_SECRET_KEY=sk_test_xxx

POSTALFORM_API_BASE=https://projects.postalform.com/api
POSTALFORM_MODE=test
POSTALFORM_TEST_API_KEY=pf_test_xxx
# POSTALFORM_LIVE_API_KEY=pf_live_xxx

# Provided by cloudflare/workers when provisioned through Stripe Projects.
CLOUDFLARE_API_TOKEN=cf_xxx
CLOUDFLARE_ACCOUNT_ID=account_xxx
CLOUDFLARE_WORKER_NAME=gym-cancellation-saas
CLOUDFLARE_WORKERS_URL=https://gym-cancellation-saas.example.workers.dev
